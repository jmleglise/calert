---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---

<Layout
  title="Contact — ConsoAlert | Wattson"
  description="Vous voulez contacter Wattson ? Il lira votre message. Mais c'est un humain qui répondra. Wattson est occupé à surveiller vos logements."
>
  <Header />

  <main class="contact-page">

    <!-- ── HERO ── -->
    <section class="contact-hero">
      <div class="container">
        
        <h1 class="contact-headline">
          Vous voulez contacter<br/>
          <span class="headline-accent">Wattson ?</span>
        </h1>
        <p class="contact-sub">
          Wattson est un agent IA. Il surveille vos logements, détecte les anomalies,
          ne dort jamais et ne prend pas de vacances.<br/>
          <strong>En revanche, il n'a pas le temps de répondre aux emails.</strong><br/>
          C'est un humain qui le fera à sa place.
        </p>

        <!-- Response time bar 
        <div class="response-pills">
          <div class="response-pill">
            <span class="pill-icon">⚡</span>
            Wattson lit : instantané
          </div>
          <div class="response-pill">
            <span class="pill-icon">🧑‍💻</span>
            Réponse humaine : quelques jours
          </div>
          <div class="response-pill">
            <span class="pill-icon">☕</span>
            Selon disponibilité du café
          </div>
        </div>
        -->
      </div>
    </section>

    <!-- ── FORM + ASIDE ── -->
    <section class="contact-section">
      <div class="container">
        <div class="contact-layout">

          <!-- ASIDE gauche -->
          <aside class="contact-aside">
            <div class="aside-block">
              <div class="aside-icon">📬</div>
              <h3 class="aside-title">Qui sommes-nous ?</h3>
              <ul class="aside-list">
                <li>
                  <span class="aside-check">✓</span>
                  ConsoAlert et Wattson sont développés à Paris.
                </li>
              </ul>
            </div>

            <div class="aside-block aside-donation">
              <div class="donation-emoji">☕</div>
              <h3 class="donation-aside-title">Offrir un café à Wattson</h3>
              <p class="donation-aside-desc">
                Wattson tourne 24h/24 sans pause. Si son travail vous a aidé,
                vous pouvez lui payer un café, c'est note seule source de motivation.
                
              </p>
              <a
                href="https://buymeacoffee.com/consoalert"
                target="_blank"
                rel="noopener"
                class="donation-aside-btn"
              >
                <svg viewBox="0 0 24 24" fill="none" class="donation-coffee-icon">
                  <path d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Faire un don
              </a>
              <p class="donation-aside-micro">Sans obligation. Wattson ne vous jugera pas.</p>
            </div>
          </aside>

          <!-- FORM -->
          <div class="form-wrapper">
            <form class="contact-form" id="contact-form" novalidate>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="nom">Nom <span class="required-star">*</span></label>
                  <input
                    class="form-input"
                    type="text"
                    id="nom"
                    name="nom"
                    placeholder="Dupont"
                    autocomplete="family-name"
                    required
                  />
                  <span class="field-error" id="error-nom">Ce champ est requis.</span>
                </div>
                <div class="form-field">
                  <label class="form-label" for="prenom">Prénom <span class="required-star">*</span></label>
                  <input
                    class="form-input"
                    type="text"
                    id="prenom"
                    name="prenom"
                    placeholder="Jean"
                    autocomplete="given-name"
                    required
                  />
                  <span class="field-error" id="error-prenom">Ce champ est requis.</span>
                </div>
              </div>

              <div class="form-field">
                <label class="form-label" for="email">Email <span class="required-star">*</span></label>
                <input
                  class="form-input"
                  type="email"
                  id="email"
                  name="email"
                  placeholder="jean.dupont@exemple.fr"
                  autocomplete="email"
                  required
                />
                <span class="field-error" id="error-email">Merci d'entrer un email valide.</span>
              </div>

              <div class="form-field">
                <label class="form-label" for="telephone">
                  Téléphone
                  <span class="optional-label">(optionnel)</span>
                </label>
                <input
                  class="form-input"
                  type="tel"
                  id="telephone"
                  name="telephone"
                  placeholder="+33 6 12 34 56 78"
                  autocomplete="tel"
                />
              </div>

              <div class="form-field">
                <label class="form-label" for="message">Message <span class="required-star">*</span></label>
                <textarea
                  class="form-input form-textarea"
                  id="message"
                  name="message"
                  rows="5"
                  placeholder="Bonjour Wattson, ..."
                  required
                ></textarea>
                <span class="field-error" id="error-message">Le message ne peut pas être vide.</span>
              </div>

              <p class="form-error" id="form-error" role="alert" aria-live="assertive"></p>

              <div class="form-field">
                <div id="turnstile-widget" class="turnstile-widget" aria-label="Vérification anti-bot Cloudflare"></div>
                <span class="field-error" id="error-turnstile">Veuillez confirmer que vous n'êtes pas un robot.</span>
              </div>

              <div class="form-footer">
                <p class="form-disclaimer">
                  
                </p>
                <button type="submit" class="form-submit" id="submit-btn">
                  <span class="submit-label">Envoyer à Wattson</span>
                  <svg class="submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </button>
              </div>
            </form>

            <!-- SUCCESS STATE -->
            <div class="success-state" id="success-state" aria-hidden="true">
              <div class="success-icon">✅</div>
              <h2 class="success-title">Wattson a reçu votre message.</h2>
              <p class="success-desc">
                Il l'a analysé, catégorisé et transmis à un humain en 0,003 secondes.
                L'humain, lui, prendra un peu plus de temps. Il fait avec les moyens du bord.
              </p>
              <p class="success-desc">
                On vous répondra dès que possible — c'est-à-dire dès qu'on aura bu notre café.
              </p>
              <a href="/fr/" class="success-back">Retour à l'accueil</a>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .contact-page {
    padding-top: 72px;
  }

  /* ── HERO ── */
  .contact-hero {
    padding: var(--spacing-24) 0 var(--spacing-16);
    text-align: center;
    background: linear-gradient(180deg, #edf8ff 0%, var(--color-body-bg) 100%);
    border-bottom: 1px solid var(--color-slate-200);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1px solid var(--color-slate-200);
    color: var(--color-text-secondary);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 16px;
    border-radius: var(--radius-full);
    margin-bottom: var(--spacing-8);
    box-shadow: var(--shadow-sm);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-blurple);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .contact-headline {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: var(--spacing-6);
  }

  .headline-accent {
    background: linear-gradient(135deg, #0ea5e9 0%, #635BFF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .contact-sub {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 600px;
    margin: 0 auto var(--spacing-10);
  }

  .contact-sub strong {
    color: var(--color-text-primary);
  }

  .response-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .response-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1px solid var(--color-slate-200);
    color: var(--color-text-secondary);
    font-size: 13px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
  }

  .pill-icon { font-size: 15px; }

  /* ── CONTACT SECTION ── */
  .contact-section {
    padding: var(--spacing-16) 0 var(--spacing-24);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-12);
    align-items: start;
  }

  @media (min-width: 960px) {
    .contact-layout {
      grid-template-columns: 340px 1fr;
      gap: var(--spacing-16);
    }
  }

  /* ── ASIDE ── */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .aside-block {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: 14px;
    padding: 28px;
    box-shadow: var(--shadow-sm);
  }

  .aside-icon {
    font-size: 32px;
    margin-bottom: var(--spacing-4);
  }

  .aside-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-5);
  }

  .aside-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .aside-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .aside-check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.12);
    color: var(--color-success-500);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    margin-top: 1px;
  }

  .aside-cross {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.1);
    color: var(--color-error-500);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    margin-top: 1px;
  }

  .aside-muted {
    color: var(--color-slate-400);
    text-decoration: line-through;
    text-decoration-color: var(--color-slate-300);
  }


  .aside-donation {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border-color: #fcd34d;
    text-align: center;
  }

  .donation-emoji {
    font-size: 40px;
    margin-bottom: var(--spacing-3);
    animation: wiggle 3s ease-in-out infinite;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-5deg); }
    75% { transform: rotate(5deg); }
  }

  .donation-aside-title {
    font-size: 16px;
    font-weight: 700;
    color: #92400e;
    margin-bottom: var(--spacing-3);
  }

  .donation-aside-desc {
    font-size: 13px;
    color: #a16207;
    line-height: 1.6;
    margin-bottom: var(--spacing-4);
  }

  .donation-aside-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #FFDD00;
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 700;
    padding: 12px 24px;
    border-radius: 10px;
    transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(255, 221, 0, 0.4);
    margin-bottom: var(--spacing-3);
  }

  .donation-aside-btn:hover {
    background: #FFE833;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 221, 0, 0.5);
  }

  .donation-coffee-icon {
    width: 18px;
    height: 18px;
  }

  .donation-aside-micro {
    font-size: 11px;
    color: #ca8a04;
    font-style: italic;
  }


  /* ── FORM ── */
  .form-wrapper {
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: 16px;
    padding: 40px;
    box-shadow: var(--shadow-sm);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }

  .form-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .required-star {
    color: var(--color-error-500);
    font-size: 13px;
  }

  .optional-label {
    font-size: 12px;
    font-weight: 400;
    color: var(--color-slate-400);
  }

  .form-input {
    font-family: var(--font-family);
    font-size: 15px;
    color: var(--color-text-primary);
    background: var(--color-slate-50);
    border: 1.5px solid var(--color-slate-200);
    border-radius: 10px;
    padding: 12px 16px;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    outline: none;
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--color-slate-400);
  }

  .form-input:focus {
    border-color: var(--color-blurple);
    background: white;
    box-shadow: 0 0 0 3px rgba(99, 91, 255, 0.1);
  }

  .form-input.invalid {
    border-color: var(--color-error-500);
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.08);
  }

  .form-textarea {
    resize: vertical;
    min-height: 130px;
    line-height: 1.6;
  }

  .field-error {
    font-size: 12px;
    color: var(--color-error-500);
    display: none;
  }

  .field-error.visible {
    display: block;
  }

  .form-error {
    color: var(--color-error-500);
    font-size: 13px;
    margin-top: -8px;
    margin-bottom: 6px;
    min-height: 18px;
  }

  #turnstile-widget {
    margin-top: 8px;
  }

  .form-footer {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
    padding-top: 8px;
  }

  @media (min-width: 640px) {
    .form-footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .form-disclaimer {
    font-size: 12px;
    color: var(--color-slate-400);
    line-height: 1.5;
    max-width: 300px;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-blurple);
    color: white;
    font-size: 15px;
    font-weight: 600;
    padding: 13px 28px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(99, 91, 255, 0.3);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .form-submit:hover {
    background: var(--color-blurple-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99, 91, 255, 0.4);
  }

  .submit-arrow {
    width: 16px;
    height: 16px;
    transition: transform 0.2s;
  }

  .form-submit:hover .submit-arrow {
    transform: translateX(3px);
  }

  /* ── SUCCESS ── */
  .success-state {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--spacing-16) var(--spacing-8);
    gap: var(--spacing-4);
  }

  .success-state.visible {
    display: flex;
  }

  .success-icon {
    font-size: 56px;
    animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes pop-in {
    from { transform: scale(0); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }

  .success-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .success-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 440px;
  }

  .success-back {
    display: inline-flex;
    align-items: center;
    background: var(--color-slate-100);
    color: var(--color-text-primary);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 24px;
    border-radius: 10px;
    margin-top: var(--spacing-4);
    transition: background 0.2s;
  }

  .success-back:hover {
    background: var(--color-slate-200);
  }
</style>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script define:vars={{ turnstileSiteKey: TURNSTILE_SITE_KEY }}>
  const form = document.getElementById('contact-form');
  const successState = document.getElementById('success-state');
  const formError = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn');
  const turnstileInitError = 'La clé publique Turnstile est manquante ou le widget ne peut pas être chargé. Votre message ne peut pas être envoyé.';
  const genericFormError = 'Impossible d’envoyer le message. Merci de réessayer plus tard.';
  let turnstileWidgetId = null;

  function setFormError(message) {
    if (formError) {
      formError.textContent = message || genericFormError;
    }
  }

  function clearFormError() {
    if (formError) {
      formError.textContent = '';
    }
  }

  function validateField(input) {
    const error = document.getElementById(`error-${input.id}`);
    let valid = true;

    if (input.required && !input.value.trim()) {
      valid = false;
    } else if (input.type === 'email' && input.value.trim()) {
      valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim());
    }

    input.classList.toggle('invalid', !valid);
    error?.classList.toggle('visible', !valid);
    return valid;
  }

  function initTurnstile() {
    const widgetHost = document.getElementById('turnstile-widget');
    const errorElement = document.getElementById('error-turnstile');

    if (!turnstileSiteKey) {
      errorElement?.classList.add('visible');
      errorElement.textContent = turnstileInitError;
      setFormError(turnstileInitError);
      if (submitBtn) submitBtn.disabled = true;
      return;
    }

    if (!widgetHost || !window.turnstile) {
      errorElement?.classList.add('visible');
      errorElement.textContent = turnstileInitError;
      setFormError(turnstileInitError);
      if (submitBtn) submitBtn.disabled = true;
      return;
    }

    turnstileWidgetId = window.turnstile.render(widgetHost, {
      sitekey: turnstileSiteKey,
      action: 'contact',
      callback() {
        errorElement?.classList.remove('visible');
      },
    });
  }

  if (document.readyState === 'complete') {
    initTurnstile();
  } else {
    window.addEventListener('load', initTurnstile);
  }

  form?.querySelectorAll('input, textarea').forEach(field => {
    field.addEventListener('blur', () => {
      if (field.value.trim() !== '' || field.classList.contains('invalid')) {
        validateField(field);
      }
    });
    field.addEventListener('input', () => {
      if (field.classList.contains('invalid')) validateField(field);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearFormError();

    const fields = form.querySelectorAll('[required]');
    let allValid = true;
    fields.forEach((field) => {
      if (!validateField(field)) allValid = false;
    });

    if (!allValid) {
      setFormError('Merci de corriger les champs en erreur.');
      return;
    }

    const token = turnstileWidgetId !== null && window.turnstile ? window.turnstile.getResponse(turnstileWidgetId) : '';
    if (!token) {
      document.getElementById('error-turnstile')?.classList.add('visible');
      setFormError('Veuillez confirmer que vous n’êtes pas un robot.');
      if (window.turnstile && turnstileWidgetId !== null) {
        window.turnstile.reset(turnstileWidgetId);
      }
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-busy', 'true');
    }

    const payload = {
      nom: form.nom.value.trim(),
      prenom: form.prenom.value.trim(),
      email: form.email.value.trim(),
      telephone: form.telephone.value.trim(),
      message: form.message.value.trim(),
      turnstileToken: token,
    };

    try {
      const response = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const responseText = await response.text();
      let result = null;

      if (responseText) {
        try {
          result = JSON.parse(responseText);
        } catch {
          result = null;
        }
      }

      if (!response.ok || result?.success !== true) {
        if (window.turnstile && turnstileWidgetId !== null) {
          window.turnstile.reset(turnstileWidgetId);
        }

        console.error('Contact form submission failed', {
          status: response.status,
          requestId: result?.requestId || response.headers.get('X-Contact-Request-Id'),
          code: result?.code,
          diagnostic: result?.diagnostic,
          detail: result?.detail,
          response: result,
        });

        setFormError(result?.error || genericFormError);
        return;
      }

      form.style.display = 'none';
      if (successState) {
        successState.style.display = 'flex';
        successState.removeAttribute('aria-hidden');
        successState.classList.add('visible');
      }
    } catch (err) {
      console.error('Contact form request crashed before receiving a response', err);

      if (window.turnstile && turnstileWidgetId !== null) {
        window.turnstile.reset(turnstileWidgetId);
