<script>
  // Billing toggle — cosmetic, all prices stay 0
  const btns = document.querySelectorAll<HTMLButtonElement>('.toggle-btn');
  const note = document.getElementById('toggle-note');

  const notes: Record<string, string> = {
    monthly: "Choisissez votre fréquence de paiement. (Spoiler : ça ne changera pas le prix.)",
    yearly:  "Vous économisez exactement 0€ par rapport au mensuel. C'est mathématique.",
  };

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const period = btn.dataset.period as string;
      if (note) note.textContent = notes[period] ?? notes.monthly;
    });
  });
</script>
