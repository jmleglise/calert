---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
const hrefFor = (page: number) => page === 1 ? basePath : `${basePath}${page}/`;
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination des articles">
    {currentPage > 1 ? <a href={hrefFor(currentPage - 1)}>← Articles récents</a> : <span />}
    <span>Page {currentPage} / {totalPages}</span>
    {currentPage < totalPages ? <a href={hrefFor(currentPage + 1)}>Articles suivants →</a> : <span />}
  </nav>
)}

<style>
  .pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--spacing-4);
    margin-top: var(--spacing-8);
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .pagination a {
    color: var(--color-blurple);
  }

  .pagination a:last-child {
    text-align: right;
  }

  @media (max-width: 640px) {
    .pagination {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .pagination a:last-child {
      text-align: center;
    }
  }
</style>
