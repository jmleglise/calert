---
import { formatDate, getPostUrl, getReadingTime, slugify, type BlogPost } from '../../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---

<article class="post-card">
  <div class="post-meta">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <span aria-hidden="true">•</span>
    <span>{getReadingTime(post)} min de lecture</span>
  </div>
  <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
  <p>{post.data.description}</p>
  <div class="post-tags" aria-label="Tags de l’article">
    {post.data.tags.map((tag) => <a href={`/fr/posts/${slugify(tag)}/`}>#{tag}</a>)}
  </div>
</article>

<style>
  .post-card {
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-sm);
    padding: var(--spacing-8);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .post-card:hover {
    border-color: color-mix(in oklab, var(--color-blurple) 35%, var(--color-slate-200));
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    color: var(--color-slate-500);
    font-size: var(--font-size-sm);
    margin-bottom: var(--spacing-3);
  }

  h2 {
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    letter-spacing: -0.03em;
    margin-bottom: var(--spacing-3);
  }

  h2 a:hover {
    color: var(--color-blurple);
  }

  p {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--spacing-5);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .post-tags a {
    color: var(--color-blurple);
    background: var(--color-primary-50);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    padding: 0.35rem 0.7rem;
  }
</style>
