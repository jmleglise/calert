---
import fr from '../i18n/fr.json';
const { partners } = fr;

const logos = [
  {
    name: 'Enedis',
    file: '/ADE_Founrisseurs_Enedis-1024x683.webp',
    height: 52,
  },
  {
    name: 'Airbnb',
    file: '/Airbnb-Logo-Horizontal-on-White-768x512.png',
    height: 42,
  },
  {
    name: 'Booking.com',
    file: '/Booking-Com-Logo-500x283.png',
    height: 36,
  },
  {
    name: 'Abritel HomeAway',
    file: '/Abritel_HomeAway_Logo.jpg',
    height: 30,
  },
];
---

<section class="partners">
  <div class="partners-container">
    {partners.title}
    <div class="partners-logos">
      {logos.map((logo) => (
        <div class="partner-logo">
          <img
            src={logo.file}
            alt={logo.name}
            height=30
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partners {
    padding: var(--spacing-12) 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    background: #FFFFFF;
  }

  .partners-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--spacing-6);
    text-align: center;
  }

  .partners-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-slate-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--spacing-8);
  }

  .partners-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-8);
  }

  @media (min-width: 768px) {
    .partners-logos {
      gap: var(--spacing-12);
    }
  }

  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-normal);
  }

  .partner-logo img {
    display: block;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    /* Grayscale + multiply so white backgrounds vanish on light bg */
    filter: grayscale(100%) opacity(0.55);
    mix-blend-mode: multiply;
    transition: filter var(--transition-normal);
  }

  .partner-logo:hover img {
    filter: grayscale(0%) opacity(1);
  }
</style>
