---
import fr from '../i18n/fr.json';
const { cards } = fr;
---

<section class="cards-section" id="features">
  <div class="cards-container">
    <div class="section-header">
      <h2 class="section-title">{cards.title}</h2>
      <p class="section-subtitle">{cards.subtitle}</p>
    </div>

    <div class="cards-grid">
      {cards.items.map((card) => (
        <article class="card" data-card={card.id}>
          <div class="card-inner">
            <div class="card-top">
              <h3 class="card-title">{card.cardTitle}</h3>
              <button class="card-expand-btn" aria-label="Agrandir">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M10 2h4v4M6 14H2v-4M14 10v4h-4M2 6V2h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class={`card-visual ${card.visualClass}`} set:html={card.visualHtml}></div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Expanded modals -->
{cards.items.map((card, index) => (
  <div class="modal-overlay" data-modal={card.id}>
    <div class="modal-panel" role="dialog" aria-modal="true">

      <button class="modal-close" data-close={card.id} aria-label="Fermer">
        <svg viewBox="0 0 14 14" fill="none">
          <path d="M13 1L1 13M1 1l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>

      <div class="modal-scroll">

        <!-- 2-column content -->
        <div class="modal-content">
          <div class="modal-col-text">
            <h2 class="modal-title">{card.title}</h2>
            <div class="modal-body-text">
              {card.body.map((paragraph: string) => (
                <p>{paragraph}</p>
              ))}
            </div>
            <a href="https://app.consoalert.com/auth" class="modal-cta-btn">
              {cards.cta}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

          <div class="modal-col-bullets">
            <ul class="modal-bullets">
              {card.bullets.map((bullet: string) => (
                <li class="modal-bullet">
                  <span class="bullet-check" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="none">
                      <path d="M3 8l3.5 3.5L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Image placeholder -->
        <div class="modal-preview">
          <div class="preview-inner">
            <div class="preview-bar">
              <span class="preview-dot"></span>
              <span class="preview-dot"></span>
              <span class="preview-dot"></span>
              <span class="preview-url">app.consoalert.com — Tableau de bord Wattson</span>
            </div>
            <div class="preview-screen">
              <div class="preview-sidebar">
                <div class="preview-nav-item active-nav"></div>
                <div class="preview-nav-item"></div>
                <div class="preview-nav-item"></div>
                <div class="preview-nav-item"></div>
              </div>
              <div class="preview-main">
                <div class="preview-row">
                  <div class="preview-card-sm gradient-blue"></div>
                  <div class="preview-card-sm gradient-green"></div>
                  <div class="preview-card-sm gradient-red"></div>
                </div>
                <div class="preview-chart-area">
                  <svg viewBox="0 0 400 100" preserveAspectRatio="none" class="preview-chart-svg">
                    <polyline points="0,80 50,70 100,60 150,65 200,30 250,25 300,35 350,20 400,25" fill="none" stroke="url(#preview-grad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="0,80 50,70 100,60 150,65 200,30 250,25 300,35 350,20 400,25 400,100 0,100" fill="url(#preview-fill)" stroke="none"/>
                    <defs>
                      <linearGradient id="preview-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="#635BFF"/>
                        <stop offset="100%" stop-color="#7C7AF5"/>
                      </linearGradient>
                      <linearGradient id="preview-fill" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#635BFF" stop-opacity="0.15"/>
                        <stop offset="100%" stop-color="#635BFF" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
))}
<style is:global>
  /* ────────────────── SECTION ────────────────── */
  .cards-section {
    padding: var(--spacing-24) 0;
  }

  .cards-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--spacing-6);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-16);
  }

  .section-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    margin-bottom: var(--spacing-4);
  }

  .section-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ────────────────── GRID ────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ────────────────── CARD SHELL ────────────────── */
  .card {
    border-radius: 7px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #FFFFFF;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    cursor: pointer;
    transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    height: 480px;
    display: flex;
    flex-direction: column;
  }

  .card:hover {
    /* box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12); */
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    transform: scale(1.02);
    border-color: rgba(0, 0, 0, 0.15);
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* ────────────────── CARD TOP ────────────────── */
  .card-top {
    padding: 32px 32px 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-shrink: 0;
  }

  .card-title {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: #0A2540;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-expand-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    padding: 8px;
    background: var(--color-blurple-icon);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .card-expand-btn svg {
    width: 16px;
    height: 16px;
  }

  .card:hover .card-expand-btn {
    background: var(--color-blurple-hover);
  }

  /* ────────────────── CARD VISUAL ────────────────── */
  .card-visual {
    flex: 1;
    position: relative;
    overflow: hidden;
    margin-top: 24px;
  }

  /* ── HEATER ── */
  .visual-heater .heater-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #fff7ed 0%, #fff 100%);
  }

  .heater-chart {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 20px 32px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 140px;
    margin-bottom: 8px;
  }

  .bar {
    flex: 1;
    background: var(--color-slate-200);
    border-radius: 4px 4px 0 0;
    transition: height 0.3s;
  }

  .bar-alert {
    background: linear-gradient(180deg, #fb923c, #ef4444);
  }

  .chart-label-empty {
    font-size: 11px;
    font-weight: 500;
    color: var(--color-slate-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
  }

  .alert-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    font-size: 12px;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 99px;
  }

  .alert-dot {
    width: 8px;
    height: 8px;
    background: #ef4444;
    border-radius: 50%;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  /* ── SAVINGS ── */
  .visual-savings .savings-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #eef2ff 0%, #fff 60%);
  }

  .savings-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 20px 32px 32px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .savings-ring svg {
    width: 120px;
    height: 120px;
  }

  .savings-items {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .saving-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: var(--color-slate-600);
  }

  .saving-item.bold {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .saving-value.positive { color: #16a34a; font-weight: 600; }
  .saving-value.negative { color: #dc2626; font-weight: 600; }

  .saving-divider {
    height: 1px;
    background: var(--color-slate-200);
    margin: 4px 0;
  }

  /* ── SQUAT ── */
  .visual-squat .squat-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #f0fdf4 0%, #fff 60%);
  }

  .squat-timeline {
    position: relative;
    z-index: 1;
    padding: 20px 32px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .timeline-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .timeline-date {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-slate-400);
    width: 28px;
  }

  .timeline-bar {
    flex: 1;
    height: 20px;
    border-radius: 4px;
    background: var(--color-slate-100);
  }

  .squat-bar {
    background: linear-gradient(90deg, #ef4444, #f97316);
  }

  .timeline-wh {
    font-size: 11px;
    color: var(--color-slate-400);
    width: 60px;
    text-align: right;
  }

  .timeline-row.alert .timeline-date { color: var(--color-slate-800); }
  .timeline-row.alert .alert-text { color: #dc2626; font-weight: 600; }

  .squat-alert {
    position: relative;
    z-index: 1;
    margin: 0 32px;
    padding: 10px 16px;
    background: #dc2626;
    color: white;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .squat-icon { width: 20px; height: 20px; flex-shrink: 0; }

  /* ── EV ── */
  .visual-ev .ev-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #f0f9ff 0%, #fff 70%);
  }

  .ev-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 16px 32px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
  }

  .ev-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate-500);
    margin-bottom: 8px;
  }

  .ev-timeline {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 100px;
  }

  .ev-slot {
    flex: 1;
    background: var(--color-slate-100);
    border-radius: 3px 3px 0 0;
  }

  .ev-charging {
    background: linear-gradient(180deg, #38bdf8, #0284c7);
  }

  .ev-hours {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--color-slate-400);
    margin-top: 4px;
  }

  .ev-cost-badge {
    display: flex;
    align-items: baseline;
    gap: 6px;
    background: #dcfce7;
    border: 1px solid #bbf7d0;
    border-radius: 12px;
    padding: 10px 16px;
  }

  .ev-cost-value { font-size: 22px; font-weight: 700; color: #16a34a; }
  .ev-cost-label { font-size: 13px; color: #15803d; }

  /* ── CLIM ── */
  .visual-clim .clim-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #eff6ff 0%, #fff 70%);
  }

  .clim-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 12px 32px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }

  .clim-gauge svg { width: 200px; height: 110px; }

  .clim-stats {
    display: flex;
    gap: 40px;
  }

  .clim-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .clim-stat-v {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .clim-stat-l {
    font-size: 11px;
    color: var(--color-slate-500);
  }

  /* ── MINING ── */
  .visual-mining .mining-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #fff1f2 0%, #fff 60%);
  }

  .mining-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 16px 0 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 12px;
  }

  .mining-line {
    height: 100px;
    overflow: hidden;
  }

  .mining-line svg {
    width: 100%;
    height: 100%;
  }

  .mining-alert {
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mining-big {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-text-primary);
    display: block;
  }

  .mining-sub {
    font-size: 11px;
    color: var(--color-slate-500);
  }

  .mining-loss {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    font-size: 15px;
    font-weight: 700;
    padding: 8px 16px;
    border-radius: 99px;
  }

  /* ── BOILER ── */
  .visual-boiler .boiler-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #fffbeb 0%, #fff 70%);
  }

  .boiler-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 20px 32px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
  }

  .boiler-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate-500);
    margin-bottom: 8px;
  }

  .boiler-grid {
    display: grid;
    grid-template-columns: repeat(24, 1fr);
    gap: 3px;
    height: 40px;
  }

  .boiler-cell {
    border-radius: 3px;
  }

  .cell-on { background: #f59e0b; }
  .cell-peak { background: #ef4444; }
  .cell-off { background: var(--color-slate-200); }
  .cell-mid { background: #fbbf24; }

  .boiler-time-labels {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--color-slate-400);
    margin-top: 4px;
  }

  .boiler-verdict {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 16px;
    border-radius: 12px;
  }

  /* ── FAULT ── */
  .visual-fault .fault-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #fef2f2 0%, #fff 60%);
  }

  .fault-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 16px 0 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 10px;
  }

  .fault-signal {
    height: 80px;
    overflow: hidden;
  }

  .fault-signal svg {
    width: 100%;
    height: 100%;
  }

  .fault-alerts {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 32px;
  }

  .fault-alert {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    background: var(--color-slate-50);
    border-radius: 8px;
    border: 1px solid var(--color-slate-200);
  }

  .fault-alert.critical {
    background: #fef2f2;
    border-color: #fecaca;
  }

  .fault-time {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-slate-400);
    font-variant-numeric: tabular-nums;
    width: 36px;
  }

  .fault-msg {
    font-size: 12px;
    color: var(--color-slate-700);
  }

  .fault-alert.critical .fault-msg {
    color: #dc2626;
    font-weight: 600;
  }

  /* ── ICAL ── */
  .visual-ical .ical-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #f0fdf4 0%, #fff 60%);
  }

  .ical-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 20px 32px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
  }

  .ical-sources {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ical-source {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-slate-700);
    font-weight: 500;
  }

  .source-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot-airbnb { background: #f43f5e; }
  .dot-booking { background: #003580; }
  .dot-abritel { background: #f97316; }

  .source-status {
    margin-left: auto;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 99px;
  }

  .source-status.synced {
    background: #dcfce7;
    color: #16a34a;
  }

  .ical-calendar {
    background: white;
    border-radius: 12px;
    border: 1px solid var(--color-slate-200);
    padding: 12px;
  }

  .ical-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }

  .ical-day-label {
    text-align: center;
    font-size: 10px;
    font-weight: 600;
    color: var(--color-slate-400);
    text-transform: uppercase;
    padding: 4px 0;
  }

  .ical-day {
    text-align: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-slate-700);
    padding: 8px 4px;
    border-radius: 8px;
  }

  .ical-day.empty { color: var(--color-slate-300); }
  .ical-day.occupied { color: white; font-weight: 600; }
  .airbnb-day { background: #f43f5e; }
  .booking-day { background: #003580; }

  /* ── DASHBOARD ── */
  .visual-dashboard .dashboard-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #f8fafc 0%, #fff 60%);
  }

  .dashboard-content {
    position: relative;
    z-index: 1;
    height: 100%;
    padding: 20px 32px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .dash-properties {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .dash-prop {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    background: var(--color-slate-50);
    border: 1px solid var(--color-slate-200);
  }

  .dash-prop.alert {
    background: #fef2f2;
    border-color: #fecaca;
  }

  .prop-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-ok { background: #22c55e; }
  .dot-alert { background: #ef4444; animation: pulse 1.5s ease-in-out infinite; }

  .prop-info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .prop-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-slate-800);
  }

  .prop-status {
    font-size: 11px;
    color: var(--color-slate-500);
  }

  .alert-status { color: #dc2626 !important; font-weight: 600; }

  /* ────────────────── MODALS ────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 37, 64, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 200;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  @media (min-width: 768px) {
    .modal-overlay {
      align-items: center;
      padding: 32px;
    }
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-panel {
    background: #FFFFFF;
    width: 100%;
    max-width: 900px;
    max-height: 92vh;
    border-radius: 16px 16px 0 0;
    position: relative;
    transform: translateY(40px);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .modal-panel {
      border-radius: 16px;
    }
  }

  .modal-overlay.active .modal-panel {
    transform: translateY(0);
  }

  /* Close button — top-right pill */
  .modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-slate-100);
    border-radius: 10px;
    color: var(--color-slate-500);
    z-index: 10;
    transition: background 0.15s, color 0.15s;
  }

  .modal-close:hover {
    background: var(--color-slate-200);
    color: var(--color-text-primary);
  }

  .modal-close svg { width: 14px; height: 14px; }

  /* Scrollable area */
  .modal-scroll {
    overflow-y: auto;
    flex: 1;
  }

  /* ── 2-column content ── */
  .modal-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 48px 36px 40px;
  }

  @media (min-width: 640px) {
    .modal-content {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      padding: 56px 52px 48px;
    }
  }

  /* Left column */
  .modal-col-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .modal-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.25;
  }

  .modal-body-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .modal-body-text p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .modal-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: white;
    background: var(--color-blurple);
    padding: 13px 28px;
    border-radius: 8px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(99, 91, 255, 0.3);
