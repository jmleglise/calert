---
import fr from '../i18n/fr.json';
const { footer, nav } = fr;
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/fr/" class="footer-logo">
          <svg class="footer-logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="currentColor"/>
            <path d="M8 16C8 16 10 10 16 10C22 10 24 16 24 16C24 16 22 22 16 22C10 22 8 16 8 16Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="16" cy="16" r="3" fill="white"/>
          </svg>
          <span class="footer-logo-text">ConsoAlert</span>
        </a>
        <p class="footer-tagline">Surveillance intelligente de la consommations electriques 24/7.</p>
      </div>

      <div class="footer-links-grid">
        <div class="footer-column">
          <h4 class="footer-heading">{footer.product}</h4>
          <ul class="footer-links">
            <li><a href="#features">Fonctionnalites</a></li>
            <li><a href="#tarifs">Tarifs</a></li>
            <li><a href="#faq">FAQ</a></li>
          </ul>
        </div>

        <div class="footer-column">
          <h4 class="footer-heading">{footer.company}</h4>
          <ul class="footer-links">
            <li><a href="/fr/posts/">Blog</a></li>
       <!--            <li><a href="/fr/about">A propos</a></li>       -->
            <li><a href="/fr/contact">Contact</a></li>
          </ul>
        </div>

        <div class="footer-column">
          <h4 class="footer-heading">{footer.legal}</h4>
          <ul class="footer-links">
            <li><a href="/fr/mentions-legales">Mentions legales</a></li>
           <!--   <li><a href="/fr/confidentialite">Confidentialite</a></li>
            <li><a href="/fr/cgv">CGV</a></li>      -->
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">{footer.copyright}</p>
