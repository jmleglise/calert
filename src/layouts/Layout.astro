---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  alternates?: Array<{ lang: string; href: string }>;
  keywords?: string[];
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = 'Agent IA intelligent qui surveille vos logements 24h/24 via Linky. Detecte anomalies, squat, abus. Sans boitier.',
  canonical,
  alternates = [
    { lang: 'fr', href: 'https://www.consoalert.com/fr/' },
    { lang: 'x-default', href: 'https://www.consoalert.com/fr/' },
  ],
  keywords = [],
  structuredData,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="generator" content={Astro.generator} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />)}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous" />
    <script is:inline>
      window.__renderConsoAlertMath = () => {
        if (!window.renderMathInElement) return false;

        window.renderMathInElement(document.querySelector('.article-content') ?? document.body, {
          delimiters: [
            { left: '$$', right: '$$', display: true },
            { left: '$', right: '$', display: false },
            { left: '\\(', right: '\\)', display: false },
            { left: '\\[', right: '\\]', display: true },
          ],
          ignoredTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
          throwOnError: false,
        });

        return true;
      };

      document.addEventListener('DOMContentLoaded', () => {
        let attempts = 0;
        const renderWhenReady = () => {
          attempts += 1;
          if (!window.__renderConsoAlertMath() && attempts < 40) {
            window.setTimeout(renderWhenReady, 125);
          }
        };

        renderWhenReady();
      });
    </script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" crossorigin="anonymous"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" crossorigin="anonymous" onload="window.__renderConsoAlertMath?.()"></script>
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    overflow-x: hidden;
  }

  /* Modal overlay styles */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(8px);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-normal), visibility var(--transition-normal);
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* Prevent body scroll when modal is open */
  body.modal-open {
    overflow: hidden;
  }
</style>